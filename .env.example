# Environment Variables for Nextfolio

# ==============================================
# EMAIL CONFIGURATION (Optional)
# ==============================================
# Gmail SMTP Configuration (if not provided, form submissions are logged locally in dev)
# To get these credentials:
# 1. Go to https://myaccount.google.com/security
# 2. Enable 2-Step Verification
# 3. Go to https://myaccount.google.com/apppasswords
# 4. Generate an app password for "Mail"
# 5. Copy the 16-digit password below

GMAIL_USER=your-email@gmail.com
GMAIL_PASSWORD=abcd efgh ijkl mnop

# ==============================================
# GITHUB GIST INTEGRATION (Optional)
# ==============================================
# Display code snippets from your GitHub Gist
# To get your Gist ID:
# 1. Create a gist at https://gist.github.com
# 2. Copy the ID from the URL (e.g., https://gist.github.com/username/YOUR_GIST_ID)

GIST_ID=your-gist-id-here

# ==============================================
# ANALYTICS (Optional)
# ==============================================
# Google Analytics Measurement ID
# Get from: https://analytics.google.com

NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ==============================================
# ALTERNATIVE EMAIL SERVICES (Optional)
# ==============================================
# Use these instead of Gmail if preferred

# SendGrid
# SENDGRID_API_KEY=your-sendgrid-api-key

# Mailgun
# MAILGUN_API_KEY=your-mailgun-api-key
# MAILGUN_DOMAIN=your-mailgun-domain

# Resend
# RESEND_API_KEY=your-resend-api-key

# ==============================================
# SECURITY (Optional)
# ==============================================
# Add rate limiting for contact form

# CONTACT_FORM_RATE_LIMIT=5
# CONTACT_FORM_RATE_WINDOW=3600000

# ==============================================
# DOMAINS & URLS (Optional)
# ==============================================
# Main website URL (defaults to http://localhost:3001 in dev, https://your-domain.dev in prod)
NEXT_PUBLIC_APP_URL=https://your-custom-domain.com

# Blog subdomain URL (defaults to http://blog.localhost:3001 in dev, https://blog.your-domain.dev in prod)
NEXT_PUBLIC_BLOG_URL=https://blog.your-custom-domain.com

# ==============================================
# NOTES
# ==============================================
# - Never commit this file with real credentials
# - Add .env.local to .gitignore (already done)
# - For production, add these to your hosting platform's environment variables
# - Restart your dev server after changing these values
